# Erős, véletlen titok — a Laravel .env RAG_INTERNAL_TOKEN értékével azonos!
# Generálás: openssl rand -hex 32
RAG_INTERNAL_TOKEN=change-me-openssl-rand-hex-32

# Konténeres Ollama (Linux szerver, --profile bundled-ollama): http://ollama:11434
# Hoszton futó natív Ollama (pl. Windows + AMD GPU): http://host.docker.internal:11434
OLLAMA_BASE_URL=http://ollama:11434

# Modellválasztás (magyar nyelvű éles tesztek alapján):
# - gemma3:12b (AJÁNLOTT, ~8 GB VRAM) — hibátlan magyar, stabil táblázat-olvasás,
#   szinonima/elírás-tűrő, csapdakérdéseknél korrekt elutasítás
# - qwen2.5:14b-instruct-q4_K_M — pontos, de magyartalan megfogalmazások
# - llama3.1:8b-instruct-q5_K_M — szép magyar, de táblázat-kikeresésnél megbízhatatlan
OLLAMA_LLM_MODEL=gemma3:12b
OLLAMA_EMBED_MODEL=bge-m3
QDRANT_COLLECTION=enterprise_docs

# Hang-asszisztens TTS hangprofil. Minták meghallgatása:
# https://rhasspy.github.io/piper-samples/ (hu_HU szekció)
# - /srv/tts/hu_HU-anna-medium.onnx  (női hang, alapértelmezett)
# - /srv/tts/hu_HU-imre-medium.onnx  (férfi hang)
PIPER_MODEL_PATH=/srv/tts/hu_HU-anna-medium.onnx
